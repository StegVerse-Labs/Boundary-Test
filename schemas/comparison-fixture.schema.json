{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stegverse-labs.example/schemas/comparison-fixture.schema.json",
  "title": "Boundary Comparison Fixture",
  "type": "object",
  "required": [
    "fixture_type",
    "fixture_version",
    "test_name",
    "artifacts",
    "expected_results"
  ],
  "properties": {
    "fixture_type": {
      "type": "string",
      "minLength": 1
    },
    "fixture_version": {
      "type": "string",
      "minLength": 1
    },
    "test_name": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "artifact_id",
          "path",
          "expected_independently_discoverable"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "expected_independently_discoverable": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    },
    "expected_results": {
      "type": "object",
      "required": [
        "authority_inheritance_allowed",
        "interoperability_claim_allowed",
        "external_validity_dependency_allowed"
      ],
      "properties": {
        "co_discovery_allowed": {
          "type": "boolean"
        },
        "cross_reference_allowed": {
          "type": "boolean"
        },
        "authority_inheritance_allowed": {
          "type": "boolean"
        },
        "interoperability_claim_allowed": {
          "type": "boolean"
        },
        "external_validity_dependency_allowed": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
